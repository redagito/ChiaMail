<Window x:Class="ChiaMail.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChiaMail - Gmail Mass Mailer"
        Icon="pack://application:,,,/logo.ico"
        Width="880" Height="780"
        MinWidth="700" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        TextOptions.TextFormattingMode="Ideal">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Source="pack://application:,,,/logo.png" Width="60" Height="60" Margin="0,0,12,0" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,24,0">
                    <TextBlock Text="ChiaMail" FontSize="20" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="Gmail Mass Mailer" FontSize="12" Foreground="#B3D4FC" />
                    <TextBlock Text="For My Kitty" FontSize="10" Foreground="#B3D4FC" />
                </StackPanel>
                <Button Grid.Column="3" Content="Help" FontSize="12"
                        Foreground="{StaticResource PrimaryBrush}" Background="White"
                        BorderThickness="1" BorderBrush="#FFFFFF44"
                        Cursor="Hand" Padding="12,4"
                        Click="Help_Click"
                        ToolTip="Open the user guide in your browser">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="6" BorderThickness="{TemplateBinding BorderThickness}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#E8F0FE" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.8" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ===== CONTENT ===== -->
        <ScrollViewer Grid.Row="1" Padding="28,20,28,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- SECTION: Gmail Account -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Gmail Account" Style="{StaticResource SectionHeaderStyle}" />

                        <TextBlock Text="Email Address" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="FromEmailTextBox" Style="{StaticResource ModernTextBox}" 
                                 ToolTip="you@gmail.com" />

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="App Password (not your regular password)" Style="{StaticResource FieldLabelStyle}" />
                                <PasswordBox x:Name="AppPasswordBox" Style="{StaticResource ModernPasswordBox}" />
                                <TextBlock Text="Must be a 16-character Gmail App Password (spaces are allowed)" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="0,0,0,10">
                                <CheckBox x:Name="SendTestMailCheckBox" Content="Send test email"
                                          IsChecked="True" Margin="0,0,0,6"
                                          FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                <Button x:Name="TestButton" Content="Test Connection" 
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="TestConnection_Click" />
                            </StackPanel>
                        </Grid>

                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" 
                                   TextWrapping="Wrap">
                            <Run Text="Need an app password? Enable 2FA on your Google account, then go to" />
                            <Hyperlink NavigateUri="https://myaccount.google.com/apppasswords" 
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                Google App Passwords
                            </Hyperlink>
                            <Run Text="and generate one." />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- SECTION: Recipients -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Recipients (CSV)" Style="{StaticResource SectionHeaderStyle}" />

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="CsvPathTextBox" Style="{StaticResource ModernTextBox}"
                                     Margin="0,0,10,0" IsReadOnly="True" 
                                     ToolTip="CSV file with Email, FirstName, LastName columns" />
                            <Button Grid.Column="1" Content="Browse..." 
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    VerticalAlignment="Top" Padding="16,8"
                                    Click="BrowseCsv_Click" />
                        </Grid>

                        <Border x:Name="CsvPreviewBorder" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6"
                                Background="{StaticResource SurfaceBrush}" MaxHeight="160" Margin="0,0,0,6"
                                Visibility="Collapsed">
                            <Grid>
                                <DataGrid x:Name="CsvPreviewGrid" Margin="0" 
                                          AutoGenerateColumns="True" />
                                <TextBlock x:Name="CsvEmptyHint" Text="No file loaded"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="13" IsHitTestVisible="False" />
                            </Grid>
                        </Border>

                        <TextBlock x:Name="RecipientCountText" FontSize="12" 
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <!-- SECTION: Email Content -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Email Content" Style="{StaticResource SectionHeaderStyle}" />

                        <TextBlock Text="Subject" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="SubjectTextBox" Style="{StaticResource ModernTextBox}"
                                  ToolTip="You can use {FirstName} and {LastName} placeholders" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Insert: " FontSize="13" 
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <Button Content="{}{FirstName}" Style="{StaticResource PlaceholderButtonStyle}" 
                                        Margin="0,0,6,0" Click="InsertPlaceholder_Click" Tag="FirstName" />
                                <Button Content="{}{LastName}" Style="{StaticResource PlaceholderButtonStyle}" 
                                        Margin="0,0,6,0" Click="InsertPlaceholder_Click" Tag="LastName" />
                                <Button Content="{}{Logo}" Style="{StaticResource PlaceholderButtonStyle}" 
                                        Click="InsertPlaceholder_Click" Tag="Logo" />
                            </StackPanel>
                            <Button Grid.Column="2" Content="Preview Email"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="16,4"
                                    Click="PreviewEmail_Click"
                                    ToolTip="Preview the email with placeholders replaced using the first recipient" />
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <RadioButton Grid.Column="0" x:Name="PlainTextRadio" Content="Plain Text"
                                         GroupName="BodyMode" IsChecked="True"
                                         FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                         Margin="0,0,20,0" VerticalAlignment="Center"
                                         Checked="BodyMode_Changed" />
                            <RadioButton Grid.Column="1" x:Name="HtmlRadio" Content="HTML"
                                         GroupName="BodyMode"
                                         FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                         VerticalAlignment="Center"
                                         Checked="BodyMode_Changed" />
                        </Grid>

                        <TextBox x:Name="BodyTextBox" Style="{StaticResource ModernTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="200" MaxHeight="400"
                                 VerticalScrollBarVisibility="Auto"
                                  ToolTip="Use {FirstName} and {LastName} placeholders. Switch to HTML mode for rich content." />
                    </StackPanel>
                </Border>

                <!-- SECTION: Company Logo -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Company Logo (Optional)" Style="{StaticResource SectionHeaderStyle}" />

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="LogoPathTextBox" Style="{StaticResource ModernTextBox}"
                                     Margin="0,0,10,0" IsReadOnly="True"
                                      ToolTip="Logo image (PNG, JPG)" />
                            <Button Grid.Column="1" Content="Browse..." 
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    VerticalAlignment="Top" Padding="16,8"
                                    Click="BrowseLogo_Click" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="100" Height="60" 
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Background="#FAFAFA"
                                    Margin="0,0,16,0" Visibility="Collapsed"
                                    x:Name="LogoPreviewBorder">
                                <Image x:Name="LogoPreviewImage" Stretch="Uniform" 
                                       MaxWidth="90" MaxHeight="50" Margin="4" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <CheckBox x:Name="IncludeLogoCheckBox" Content="Include logo in emails"
                                          FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                                          IsChecked="True" Margin="0,0,0,4" />
                                <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap">
                                    The logo will be embedded inline at the bottom of each email.
                                    Use <Run FontFamily="Consolas" Text="{}{Logo}" /> in the body to place it elsewhere.
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- SECTION: Attachments -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Attachments" Style="{StaticResource SectionHeaderStyle}" />

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="AttachmentPathTextBox" 
                                     Style="{StaticResource ModernTextBox}" IsReadOnly="True"
                                     Margin="0,0,10,0" FontSize="13"
                                     ToolTip="Optional files to attach to every email (PDFs, docs, etc.)" />
                            <Button Grid.Column="1" Content="Add Files..."
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    VerticalAlignment="Top" Padding="16,8"
                                    Click="AddAttachments_Click" />
                        </Grid>

                        <ListBox x:Name="AttachmentListBox" MaxHeight="100" Margin="0,0,0,4"
                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                 Background="#FAFBFC" FontSize="12"
                                 Visibility="Collapsed">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" 
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="✕" FontSize="11"
                                                Width="20" Height="20" Padding="0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Tag="{Binding}"
                                                Click="RemoveAttachment_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Bottom spacer -->
                <Rectangle Height="8" Fill="Transparent" />

            </StackPanel>
        </ScrollViewer>

        <!-- ===== PROGRESS ===== -->
        <Border Grid.Row="2" Padding="28,8,28,4" Background="{StaticResource SurfaceBrush}">
            <StackPanel>
                <ProgressBar x:Name="SendProgressBar" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ProgressText" Grid.Column="0"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" 
                               Visibility="Collapsed" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- ===== BOTTOM BAR ===== -->
        <Border Grid.Row="3" Padding="28,8,28,16" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Status Log -->
                <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" 
                        BorderThickness="1" CornerRadius="6" MaxHeight="80"
                        Margin="0,0,16,0" Background="#FAFBFC">
                    <ListBox x:Name="StatusLogListBox" 
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             FontSize="12" Foreground="{StaticResource TextPrimaryBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12" 
                                           LineHeight="18" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- Delay control -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,16,0">
                    <TextBlock Text="Delay:" FontSize="13" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0" />
                    <TextBox x:Name="DelayTextBox" Text="5" Width="48" TextAlignment="Center"
                             ToolTip="Seconds to wait between each email (prevents Gmail rate limiting)"
                             Style="{StaticResource ModernTextBox}"
                             VerticalAlignment="Center"
                             PreviewTextInput="DelayTextBox_PreviewTextInput"
                             DataObject.Pasting="DelayTextBox_Pasting" />
                    <TextBlock Text="sec" FontSize="13" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0,0,0" />
                </StackPanel>

                <!-- Send / Cancel Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="TestSelfButton" Content="Send Test to Self"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,10,0"
                            Click="TestSelf_Click"
                            ToolTip="Sends a preview email to yourself with the current subject, body, logo and attachments" />
                    <Button x:Name="CancelButton" Content="Cancel"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,10,0"
                            Visibility="Collapsed"
                            Click="Cancel_Click" />
                    <Button x:Name="ScreenshotButton" Content="📷"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,10,0" FontSize="15" Padding="8,7"
                            Click="TakeScreenshot"
                            ToolTip="Save a screenshot of this window (Ctrl+Shift+S)" />
                    <Button x:Name="SendButton" Content="Send All Emails"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="28,12" FontSize="15"
                            Click="Send_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
